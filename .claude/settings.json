{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "https://REPLACE_WITH_DENO_DEPLOY_URL/hook",
            "headers": {
              "X-Thermal-Key": "$THERMAL_API_KEY"
            },
            "allowedEnvVars": ["THERMAL_API_KEY"],
            "timeout": 15
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "http",
            "url": "https://REPLACE_WITH_DENO_DEPLOY_URL/hook",
            "headers": {
              "X-Thermal-Key": "$THERMAL_API_KEY"
            },
            "allowedEnvVars": ["THERMAL_API_KEY"],
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "deno run --allow-read --allow-net --allow-env ~/.claude/hooks/stop-hook.ts",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "deno run --allow-read --allow-net --allow-env ~/.claude/hooks/session-hook.ts",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ]
  }
}
